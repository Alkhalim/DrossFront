#!/usr/bin/env python
import os

env = Environment()
env.Append(CPPPATH=["../src/", "../godot-cpp/include/", "../godot-cpp/gen/include/", "../godot-cpp/gdextension/"])
if env["PLATFORM"] == "win32":
    # /std:c++17 — language standard. /EHsc — synchronous C++ exceptions
    # (required by doctest's REQUIRE / CHECK_FALSE which throw to halt
    # a TEST_CASE on a fatal failure). Without /EHsc, doctest's static
    # assertion fires at compile time.
    # /DMOVEMENT_NATIVE_TESTS — stubs out the godot-cpp method-bind
    # machinery in _bind_methods() bodies; the test binary doesn't
    # have the loaded-extension runtime that bind_method needs.
    env.Append(CXXFLAGS=["/std:c++17", "/EHsc", "/DMOVEMENT_NATIVE_TESTS"])
else:
    env.Append(CXXFLAGS=["-std=c++17", "-DMOVEMENT_NATIVE_TESTS"])

# Link godot-cpp's static library so non-inline godot::Vector2 / AABB
# / String / etc. methods (e.g. Vector2::length, Vector2::normalized)
# resolve. Built once by the main GDExtension SConstruct; if missing,
# build the main extension first via build.ps1.
env.Append(LIBPATH=["../godot-cpp/bin/"])
env.Append(LIBS=["libgodot-cpp.windows.template_debug.x86_64"])

# Test placement convention (post-PF-B-A0):
# - Impl-class doctests live in native/movement/tests/test_<name>.cpp
#   and link against ../src/<name>_impl.cpp directly.
# - Façades (godot::Object subclasses) cannot be tested here — their
#   constructor SIGSEGVs without a loaded Godot runtime. Verify those
#   paths via tools/test_*.gd headless snapshot tests instead.
sources = ["test_main.cpp", "test_cost_grid.cpp", "test_flow_field.cpp",
           "../src/cost_grid.cpp", "../src/flow_field.cpp",
           "../src/steering_kernel_impl.cpp", "../src/flow_field_server_impl.cpp"]
env.Program(target="run_tests", source=sources)
