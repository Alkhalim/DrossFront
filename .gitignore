# Godot 4 specific ignores
.godot/*
# Exception: extension_list.cfg must be tracked so headless runs find
# the movement_native GDExtension without an editor pass. Pattern uses
# .godot/* (not .godot/) so this re-include works — git can't re-include
# files from a fully-excluded parent directory.
!.godot/extension_list.cfg

# Imported resources
.import/

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# IDE
*.swp
*.swo
*~
.vscode/
.idea/

# Export
export/
*.pck
*.zip

# MSVC sidecars from GDExtension builds (lib import file, exports table,
# debug symbols). The .dll itself is tracked; these aren't.
addons/movement_native/bin/*.lib
addons/movement_native/bin/*.exp
addons/movement_native/bin/*.pdb

# Linker temp DLLs that show up if the build doesn't atomically rename
# the final output (file was held open or a previous run was killed
# mid-link). The real DLL has no leading tilde.
addons/movement_native/bin/~*.dll

# Native build outputs and Godot's auto-imported sidecars for them.
# C++ object files and the .obj.import resources Godot generates when
# it scans the native source tree as a project resource.
native/**/*.obj
native/**/*.os
native/**/*.obj.import
