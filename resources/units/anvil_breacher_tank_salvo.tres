special_description = "Breacher Salvo branch — main gun replaced by a six-tube rocket battery that ripples all six rockets in tight succession. Each consecutive salvo at the same target shortens the next reload by 10%, capped at 55% off (cycle floor ~1.6s). Locks onto a target and tears it apart faster the longer it stays painted."
passive_description = "Lock-On Cycle — every consecutive salvo at the same target shortens the next reload (-10% per shot, max -55%). Resets when the target changes."
branch_summary = "Six-tube ripple-fire rocket battery with a fire-rate ramp -- best when you can keep the squad painting one heavy mech."
